<h1>Sign In to your account!</h1>

<%= form_with url: signin_path do |f| %>
    <p>
      <%= f.label :email %> 
      <%= f.email_field :email %> 
    </p>

    <p>
      <%= f.label :password %> 
      <%= f.password_field :password %> 
    </p>

    <p>
      <%= f.submit "Sign in" %> 
    </p>
<% end %>


<%# session used for the sign in page that allows users to of course log into their account %>